{
  "manifest_version": 3,
  "name": "TenUp App Sync",
  "version": "0.1.0",
  "description": "Synchronise les resultats TenUp vers le dashboard TenUp App.",
  "permissions": [
    "alarms",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://tenup.fft.fr/*",
    "https://tenup-app-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TenUp Sync",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tenup.fft.fr/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "https://tenup.fft.fr/*"
      ]
    }
  ]
}
